<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <xacro:macro name="imu_sensor_xacro" params="">
    <gazebo reference="base_link">
      <sensor name="kaqu_imu_sensor" type="imu">
        <pose>0 0 0.02 0 0 0</pose>
        <always_on>true</always_on>
        <update_rate>100.0</update_rate>
        <topic>imu</topic>
        <imu/> 
         <!--imu 속도, 가속도, 방향-->
      </sensor>
    </gazebo>
  </xacro:macro>
</robot>
